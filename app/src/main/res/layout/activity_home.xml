<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_black">

    <ScrollView
        android:id="@+id/scroll_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Page header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="8dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_location_pin"
                    app:tint="@color/text_gold" />

                <TextView
                    android:id="@+id/tv_page_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="Current Position"
                    android:textColor="@color/text_gold"
                    android:textSize="26sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Action buttons row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end|center_vertical"
                android:orientation="horizontal"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingBottom="4dp">

                <ImageView
                    android:id="@+id/btn_calibrate"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_calibrate"
                    android:contentDescription="Calibrate"
                    android:padding="4dp"
                    app:tint="@color/text_gold" />

                <ImageView
                    android:id="@+id/btn_info"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="12dp"
                    android:src="@drawable/ic_info"
                    android:contentDescription="Info"
                    android:padding="4dp"
                    app:tint="@color/text_gold" />
            </LinearLayout>

            <!-- Section title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="8dp"
                android:text="Room"
                android:textColor="@color/text_gold"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- ✅ Current Position card -> replaced by SVG (WebView with zoom) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_dark_gold"
                android:orientation="vertical"
                android:padding="12dp">

                <WebView
                    android:id="@+id/web_position_card"
                    android:layout_width="match_parent"
                    android:layout_height="260dp"
                    android:background="@color/surface_black" />

            </LinearLayout>

            <!-- ✅ floor/room/building text moved below SVG card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_card_dark"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tv_current_room"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Room: Unknown"
                    android:textColor="@color/text_gold"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_current_floor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Floor: Unknown"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tv_current_building"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Building: Unknown"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tv_coordinates"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Position: --, --"
                    android:textColor="@color/text_gold"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tv_fingerprint_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="DB: 0 fingerprints"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Sync age ticker -->
            <TextView
                android:id="@+id/tv_sync_age"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="updated 0s ago"
                android:textColor="@color/text_gold"
                android:textSize="13sp"
                android:fontFamily="monospace" />

            <View
                android:layout_width="match_parent"
                android:layout_height="12dp" />

            <!-- Wi-Fi Debug -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_dark"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="Wi-Fi Debug"
                    android:textColor="@color/text_gold"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_wifi_info"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/surface_black"
                    android:padding="12dp"
                    android:text="Loading..."
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="12dp" />

        </LinearLayout>
    </ScrollView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_refresh"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        android:contentDescription="Refresh"
        app:backgroundTint="@color/text_gold"
        app:srcCompat="@drawable/ic_refresh"
        app:tint="@android:color/black" />
</FrameLayout>
